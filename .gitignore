/.meta-workspace/

# Local operator files must never be committed.
/.env
/.env.*
!/.env.example

# Scratch output for split/audit experiments.
/split-reports/
/generated-reports/

# generated simctl caches (docsite, simdoc, brochure previews)
.sim/
